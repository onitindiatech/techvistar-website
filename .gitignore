*.sw?

# Monorepo separation rules
frontend/node_modules
frontend/dist
frontend/dist-ssr
frontend/*.local
frontend/.env
frontend/.env.local
frontend/.env.production.local

backend/node_modules
backend/dist
backend/.env
backend/logs/
backend/uploads/

