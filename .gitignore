# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Root-level node_modules guard (root has no package.json — this prevents accidents)
/node_modules
/package-lock.json

node_modules
dist
dist-ssr
coverage
*.local

# Environment files (never commit secrets)
.env
/.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Monorepo separation rules
frontend/node_modules
frontend/dist
frontend/dist-ssr
frontend/*.local

backend/node_modules
backend/dist
backend/.env
backend/logs/
backend/uploads/

# Temporary Vite config parsing timestamps
*.timestamp-*.mjs
*.timestamp-*.js

# Temporary Render simulation / local test copies
_render_isolated/
backend/_render_sim/

# Cloudinary migration run logs (written under backend/logs/)
backend/logs/cloudinary-migration-*.json
