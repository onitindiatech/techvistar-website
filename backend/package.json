{
  "name": "techvistar-backend",
  "version": "1.0.0",
  "description": "TypeScript backend starter architecture for TechVistar",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "ts-node -r tsconfig-paths/register --transpile-only src/utils/mediaAsset.test.ts && ts-node -r tsconfig-paths/register --transpile-only src/services/cloudinary.service.test.ts",
    "seed:industries": "ts-node-dev --transpile-only -r tsconfig-paths/register src/database/seedIndustries.ts",
    "seed:solutions": "ts-node-dev --transpile-only -r tsconfig-paths/register src/database/seedSolutions.ts",
    "seed:portfolio": "ts-node-dev --transpile-only -r tsconfig-paths/register src/database/seedPortfolio.ts",
    "migrate:cloudinary": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-cloudinary-assets.ts",
    "migrate:cloudinary:dry-run": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-cloudinary-assets.ts --dry-run",
    "migrate:cloudinary:verify": "ts-node -r tsconfig-paths/register --transpile-only scripts/migrate-cloudinary-assets.ts --verify-only"
  },
  "keywords": [
    "express",
    "typescript",
    "node",
    "saas"
  ],
  "author": "TechVistar Development Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
