# TechVistar Frontend — environment template
# Copy to .env for local development. Do not commit real secrets.

# Backend API URL (local dev: http://localhost:5000 — production: your deployed HTTPS URL)
VITE_API_BASE_URL=http://localhost:5000

# Public Cloudinary cloud name — must match backend CLOUDINARY_CLOUD_NAME
# Used only to build delivery URLs from stored public_id values (not a secret).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional — canonical site URL for SEO defaults
VITE_SITE_URL=https://techvistar.com
