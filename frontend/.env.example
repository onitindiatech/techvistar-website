# TechVistar Frontend — set these in Vercel Project Settings → Environment Variables
# Required at BUILD time (Vite inlines VITE_* variables).

# Production API URL (deploy backend first, then paste its HTTPS URL here)
# MUST be set in Vercel → Settings → Environment Variables → Production, then redeploy.
VITE_API_BASE_URL=https://techvistar-backend.onrender.com

# Public site URL (canonical / SEO)
VITE_SITE_URL=https://techvistar.com
